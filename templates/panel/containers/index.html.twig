{% extends 'layouts/panel.html.twig' %}

{% block title %}{{ 'containers.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <a href="{{ path('panel_dashboard') }}" class="hover:text-gray-700">{{ 'nav.breadcrumb.panel'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <a href="{{ path('panel_server_overview') }}" class="hover:text-gray-700">{{ 'nav.section.server'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <span class="font-medium text-gray-900">{{ 'containers.title'|trans }}</span>
{% endblock %}

{% block content %}
    <div
        data-controller="symfony--ux-turbo--mercure-turbo-stream"
        data-symfony--ux-turbo--mercure-turbo-stream-hub-value="{{ mercure() }}"
        data-symfony--ux-turbo--mercure-turbo-stream-topic-value="sfpanel://containers"
    ></div>

    <div class="space-y-6">
        {# Header #}
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">{{ 'containers.title'|trans }}</h1>
                <p class="mt-1 text-sm text-muted-foreground">{{ 'containers.subtitle'|trans }}</p>
            </div>
        </div>

        {# Tab navigation #}
        <div class="border-b border-gray-200">
            <nav class="-mb-px flex gap-6" aria-label="Tabs">
                <a href="{{ path('panel_containers') }}"
                   class="border-b-2 border-primary px-1 pb-3 text-sm font-medium text-primary">
                    {{ 'containers.tab.containers'|trans }}
                </a>
                <a href="{{ path('panel_container_stacks') }}"
                   class="border-b-2 border-transparent px-1 pb-3 text-sm font-medium text-muted-foreground hover:border-gray-300 hover:text-gray-700">
                    {{ 'containers.tab.stacks'|trans }}
                </a>
            </nav>
        </div>

        {# Container table #}
        <twig:Card class="py-0 gap-0 overflow-hidden">
            <table class="min-w-full divide-y divide-border">
                <thead class="bg-muted/50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">{{ 'containers.th.name'|trans }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">{{ 'containers.th.image'|trans }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">{{ 'containers.th.status'|trans }}</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">{{ 'containers.th.ports'|trans }}</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-muted-foreground uppercase tracking-wider">{{ 'containers.th.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody id="containers-table-body" class="divide-y divide-border">
                    {% include '@containers/panel/containers/_list_rows.html.twig' %}
                </tbody>
            </table>
        </twig:Card>
    </div>
{% endblock %}
