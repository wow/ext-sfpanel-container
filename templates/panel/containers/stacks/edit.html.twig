{% extends 'layouts/panel.html.twig' %}

{% block title %}{{ 'stacks.edit.title'|trans({'%name%': stack.name}) }}{% endblock %}

{% block breadcrumbs %}
    <a href="{{ path('panel_dashboard') }}" class="hover:text-gray-700">{{ 'nav.breadcrumb.panel'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <a href="{{ path('panel_containers') }}" class="hover:text-gray-700">{{ 'containers.title'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <a href="{{ path('panel_container_stacks_show', {name: stack.name}) }}" class="hover:text-gray-700">{{ stack.name }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <span class="font-medium text-gray-900">{{ 'stacks.edit.breadcrumb'|trans }}</span>
{% endblock %}

{% block content %}
    <div class="max-w-3xl space-y-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'stacks.edit.title'|trans({'%name%': stack.name}) }}</h1>
            <p class="mt-1 text-sm text-muted-foreground">{{ 'stacks.edit.subtitle'|trans }}</p>
        </div>

        <twig:Card>
            <div class="px-6">
                <form method="post" action="{{ path('panel_container_stacks_save', {name: stack.name}) }}" class="space-y-5">
                    <input type="hidden" name="_token" value="{{ csrf_token('stack_edit_' ~ stack.name) }}">

                    <div data-controller="code-editor" data-code-editor-language-value="yaml">
                        <twig:Form:Label for="compose_content">{{ 'stacks.form.compose_file'|trans }}</twig:Form:Label>
                        <textarea name="compose_content" id="compose_content"
                                  data-code-editor-target="textarea"
                                  class="hidden">{{ composeContent }}</textarea>
                        <div data-code-editor-target="editor" class="mt-1 min-h-[400px]"></div>
                    </div>

                    <div class="flex items-center gap-3 pt-4 border-t">
                        <twig:Button type="submit">{{ 'stacks.form.save_btn'|trans }}</twig:Button>
                        <twig:Button as="a" href="{{ path('panel_container_stacks_show', {name: stack.name}) }}" variant="outline">{{ 'stacks.form.cancel'|trans }}</twig:Button>
                    </div>
                </form>
            </div>
        </twig:Card>
    </div>
{% endblock %}
