{% extends 'layouts/panel.html.twig' %}

{% block title %}{{ 'stacks.create.title'|trans }}{% endblock %}

{% block breadcrumbs %}
    <a href="{{ path('panel_dashboard') }}" class="hover:text-gray-700">{{ 'nav.breadcrumb.panel'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <a href="{{ path('panel_containers') }}" class="hover:text-gray-700">{{ 'containers.title'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <a href="{{ path('panel_container_stacks') }}" class="hover:text-gray-700">{{ 'stacks.title'|trans }}</a>
    <svg class="h-4 w-4 text-gray-400 mx-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    <span class="font-medium text-gray-900">{{ 'stacks.create.title'|trans }}</span>
{% endblock %}

{% block content %}
    <div class="max-w-3xl space-y-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">{{ 'stacks.create.title'|trans }}</h1>
            <p class="mt-1 text-sm text-muted-foreground">{{ 'stacks.create.subtitle'|trans }}</p>
        </div>

        <twig:Card>
            <div class="px-6">
                <form method="post" action="{{ path('panel_container_stacks_create') }}" class="space-y-5">
                    <input type="hidden" name="_token" value="{{ csrf_token('stack_create') }}">

                    <div>
                        <twig:Form:Label for="stack_name">{{ 'stacks.form.name'|trans }}</twig:Form:Label>
                        <twig:Form:Input name="name" id="stack_name" required class="mt-1"
                               placeholder="{{ 'stacks.form.name_placeholder'|trans }}"
                               pattern="[a-z0-9][a-z0-9-]*" />
                        <twig:Form:Hint>{{ 'stacks.form.name_hint'|trans }}</twig:Form:Hint>
                    </div>

                    <div data-controller="code-editor" data-code-editor-language-value="yaml">
                        <twig:Form:Label for="compose_content">{{ 'stacks.form.compose_file'|trans }}</twig:Form:Label>
                        <textarea name="compose_content" id="compose_content"
                                  data-code-editor-target="textarea"
                                  class="hidden">{{ 'stacks.form.compose_template'|trans }}</textarea>
                        <div data-code-editor-target="editor" class="mt-1 min-h-[300px]"></div>
                        <twig:Form:Hint>{{ 'stacks.form.compose_hint'|trans }}</twig:Form:Hint>
                    </div>

                    <div class="flex items-center gap-2">
                        <twig:Form:Checkbox name="deploy_after" id="deploy_after" />
                        <twig:Form:Label for="deploy_after" class="!mb-0">{{ 'stacks.form.deploy_after'|trans }}</twig:Form:Label>
                    </div>

                    <div class="flex items-center gap-3 pt-4 border-t">
                        <twig:Button type="submit">{{ 'stacks.form.create_btn'|trans }}</twig:Button>
                        <twig:Button as="a" href="{{ path('panel_container_stacks') }}" variant="outline">{{ 'stacks.form.cancel'|trans }}</twig:Button>
                    </div>
                </form>
            </div>
        </twig:Card>
    </div>
{% endblock %}
